{
  "name": "car-calling-backend",
  "version": "1.0.0",
  "description": "Backend API for Car Calling application",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --detectOpenHandles",
    "init-db": "node src/scripts/initDatabase.js",
    "seed": "node src/scripts/seed.js",
    "promote-admin": "node src/scripts/promoteToAdmin.js",
    "set-password": "node src/scripts/setUserPassword.js",
    "cleanup-project-data": "node src/scripts/cleanupProjectData.js",
    "reset-data": "node src/scripts/cleanupProjectData.js --yes --all-users",
    "lint": "eslint ."
  },
  "keywords": [
    "car",
    "rental",
    "api",
    "mongodb",
    "express"
  ],
  "author": "Car Calling Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "testTimeout": 30000
  }
}
